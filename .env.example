# Knowrizon AI — Environment Variables
# Copy this file to .env and fill in your values.

# ──────────────────────────────────────
# Supabase (PostgreSQL database)
# ──────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=sb_publishable_your-key-here
DATABASE_URL=postgresql://postgres.your-project:your-password@aws-0-region.pooler.supabase.com:5432/postgres?sslmode=require

# ──────────────────────────────────────
# Pusher Channels (real-time WebSocket)
# ──────────────────────────────────────
PUSHER_APP_ID=your_app_id
PUSHER_KEY=your_key
PUSHER_SECRET=your_secret
PUSHER_CLUSTER=ap1

# ──────────────────────────────────────
# Pusher client keys (exposed to browser)
# ──────────────────────────────────────
NEXT_PUBLIC_PUSHER_KEY=your_key
NEXT_PUBLIC_PUSHER_CLUSTER=ap1

# ──────────────────────────────────────
# AI Services
# ──────────────────────────────────────
NEBIUS_API_KEY=your_nebius_api_key

# ──────────────────────────────────────
# Flask
# ──────────────────────────────────────
FLASK_ENV=production
SECRET_KEY=change-me-to-a-random-string
