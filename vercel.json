{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "builds": [
    {
      "src": "app.py",
      "use": "@vercel/python"
    },
    {
      "src": "frontend/dist/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "app.py" },
    { "src": "/assets/(.*)", "dest": "frontend/dist/assets/$1" },
    { "src": "/logo.svg", "dest": "frontend/dist/logo.svg" },
    { "src": "/vite.svg", "dest": "frontend/dist/vite.svg" },
    { "src": "/(.*\\.(js|css|ico|png|jpg|jpeg|gif|svg|woff|woff2|ttf|eot|map|webp))", "dest": "frontend/dist/$1" },
    { "src": "/(.*)", "dest": "app.py" }
  ],
  "functions": {
    "api/**/*.py": {
      "maxDuration": 30
    },
    "app.py": {
      "maxDuration": 30
    }
  }
}
